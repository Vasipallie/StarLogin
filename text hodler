app.post('/login', async (req, res) => {
    const { data, error } = await supabaseClient.auth.signInWithPassword({
        email: req.body.email,
        password: req.body.password,
    });
    if (error) {
        console.error('Error signing in:', error.message);
        return res.status(401).send('Authentication failed');
    }
    const token = data.session.access_token;
    res.cookie('auth_token', token, { httpOnly: true, secure: true });
    res.redirect('/connection?provider=' + req.body.provider + '&providerimg=' + req.body.providerimg );
});
app.route('/connection').get((req, res) => {
    const provider = req.query.provider
    const provider_img = req.query.providerimg 
    const bckimg = 'assets/bcks/' + randoimg();
    res.render('connect', { provider, provider_img, bckimg });
});

