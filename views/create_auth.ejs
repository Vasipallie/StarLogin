<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StarLogin Authenticate</title>
    <style>
        @font-face{
            font-family: 'Geomanist';
            src: url('../assets/Geomanist-Regular.otf') format('opentype');
        }
        @font-face{
            font-family: 'OpenSans';
            src: url('../assets/opensans.ttf') format('truetype');
        }
        body {
            font-family: 'OpenSans', sans-serif;
            color: #FFFFFF;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background-color: #303030;
            background-image: url('../<%= bckimg %>');
            background-size: cover;
            background-repeat: no-repeat;
            background-position: center;
            
        }
        .contain{
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: stretch;
            gap: 0;
            background: linear-gradient(135deg,#2a1d18, #000000);
            box-shadow: 0 4px 8px rgba(255, 255, 255, 0.342);
            padding: 20px;
            border-radius: 10px;
            width: min(100%, 400px);
            max-width: 400px;
            max-height: 900px;
        }
        .contain > * {
            margin-top: 0;
            margin-bottom: 0;
        }
        .provider {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
            align-self: center;
            width: 100%;
            max-width: 100%;
            border-radius: 999px;
            border: 1px solid rgba(255, 255, 255, 0.38);
            background: rgba(255, 255, 255, 0.06);
            padding: 6px 10px;
            margin-bottom: 20px;
            box-sizing: border-box;
            flex-wrap: wrap;
        }
        .provider img {
            max-width: 100%;
            height: auto;
            object-fit: contain;
        }
        .input-wrap {
            width: 100%;
            margin-top: 12px;
        }
        form {
            width: 100%;
            display: flex;
            flex-direction: column;
        }
        .input-label {
            display: block;
            margin-bottom: 6px;
            font-family: 'Geomanist', sans-serif;
            font-size: 13px;
            letter-spacing: 0.4px;
            color: rgba(255, 255, 255, 0.85);
        }
        input[type="email"], input[type="password"]{
            width: 100%;
            box-sizing: border-box;
            background: rgba(255, 255, 255, 0.96);
            font-family: 'Geomanist', sans-serif;
            font-size: 16px;
            color: #111111;
            border-radius: 10px;
            border: 1px solid rgba(255, 255, 255, 0.25);
            padding: 12px 14px;
            transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
        }
        input[type="email"]::placeholder, input[type="password"]::placeholder {
            color: #777777;
        }
        input[type="email"]:focus, input[type="password"]:focus {
            outline: none;
            border-color: #f4b560;
            box-shadow: 0 0 0 3px rgba(244, 181, 96, 0.28);
            background: #ffffff;
        }
        h1,h2,h3,h4,h5,h6{
            font-family: 'Geomanist', sans-serif;
        }
        button {
            margin-top: 12px;
            width: 100%;
            padding: 12px;
            background-color: #FF5F00;
            color: #111111;
            font-family: 'Geomanist', sans-serif;
            font-weight: 900;
            font-size: 16px;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            transition: background-color 0.2s ease, box-shadow 0.2s ease;
        }
        .contain > button {
            margin-top: 12px;
        }
        .a-style{
            color:#FF5F00;
            display: flex;
            margin-top: 12px;
            justify-content: space-between;
            width: 80%;
        }
        a{
            color:#FF5F00;
            text-decoration: none;
            font-size: 14px;
            transition: color 0.2s ease;
        }
        a:hover {
            color: #ff7f50;
        }
        a:active {
            color: #ff3b00;
        }
        @media (max-width: 768px) {
            body {
                padding: 20px;
                height: auto;
                min-height: 100vh;
            }
            .contain {
                max-width: 100%;
                max-height: none;
                padding: 16px;
                margin: auto;
            }
            .provider {
                gap: 8px;
                padding: 4px 8px;
                margin-bottom: 16px;
            }
            .provider img {
                max-width: 100%;
                height: auto;
            }
            h2 {
                font-size: 16px;
                line-height: 1.4;
                margin: 0 !important;
                padding: 0 8px;
            }
            .input-wrap {
                margin-top: 10px;
            }
            .input-label {
                font-size: 12px;
            }
            input[type="email"], input[type="password"] {
                font-size: 16px;
                padding: 10px 12px;
            }
            button {
                font-size: 14px;
                padding: 10px;
                margin-top: 10px;
            }
            .a-style {
                width: 90%;
                font-size: 12px;
                margin-top: 10px;
            }
            a {
                font-size: 12px;
            }
        }
        @media (max-width: 480px) {
            body {
                padding: 12px;
            }
            .contain {
                padding: 12px;
                border-radius: 8px;
            }
            .provider {
                flex-wrap: wrap;
                gap: 6px;
                padding: 3px 6px;
                margin-bottom: 12px;
            }
            .provider img {
                width: 60px !important;
                height: auto !important;
                max-width: 100%;
            }
            h2 {
                font-size: 14px;
                line-height: 1.3;
            }
            .input-wrap {
                margin-top: 8px;
            }
            .input-label {
                font-size: 11px;
            }
            input[type="email"], input[type="password"] {
                font-size: 14px;
                padding: 8px 10px;
            }
            button {
                font-size: 13px;
                padding: 8px;
                margin-top: 8px;
            }
            .a-style {
                width: 95%;
                font-size: 11px;
                margin-top: 8px;
                flex-direction: column;
                gap: 6px;
                justify-content: center;
            }
            a {
                font-size: 11px;
                justify-content: center !important;
            }
        }
        hr{
            border:none;
            border-top: 1px solid rgba(255, 255, 255, 0.25);
        }
        .nameHolders{
            display:flex;
            gap:10px;
            margin-block: 30px;
        }
        input[type="text"]{
            width: 100%;
            box-sizing: border-box;
            background: rgba(255, 255, 255, 0.96);
            font-family: 'Geomanist', sans-serif;
            font-size: 16px;
            color: #111111;
            border-radius: 10px;
            border: 1px solid rgba(255, 255, 255, 0.25);
            padding: 12px 14px;
            transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
        }
    </style>
</head>
<body>
    <div class="contain">
        <div class="provider">
            <img src="../assets/skw.png" alt="StarKloud Auth" style="max-width: 80px; height: auto;"> <img src="../assets/swap.png" alt="connection to" style="max-width: 20px; height: auto;"> <img src="<%= provider_img %>" alt="<%= provider %>" style="max-width: 70px; height: auto;" class="provider-img">
        </div>
        
                <h2 style="text-align: center;">Create a StarKloud Account</h2>
                <hr>
                <span style="text-align: center;">Create an account to continue to <%= provider %></span>
        <form action="/login" method="POST">
            <input type="hidden" name="authID" value="<%= authID %>">
            <div>
                <div class="nameHolders">
                    <div>
                        <label for="name" class="input-label">First Name</label>
                        <input type="text" id="name" name="name" class="input-wrapper" placeholder="Enter your first name">
                    </div>
                    <div>
                        <label for="lname" class="input-label">Last Name</label>
                        <input type="text" id="lname" name="lname" class="input-wrapper" placeholder="Enter your last name">
                    </div>
                </div>
                <label for="email" class="input-label">Email Address</label>
                <input type="email" id="email" name="email" placeholder="Enter your email">

                <label for="password" class="input-label">Password</label>
                <input type="password" id="password" name="password" placeholder="Enter your password">

                <button type="submit">Create Account</button>
                <p>By creating an account, you agree to our <a href="/terms">Terms of Service</a> and <a href="/privacy">Privacy Policy</a>.</p>
            </div>
        </form>
        
</body>
</html>