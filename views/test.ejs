<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StarLogin Test</title>
    <style>
        @font-face{
            font-family: 'Geomanist';
            src: url('../assets/Geomanist-Regular.otf') format('opentype');
        }
        body {
            font-family: 'Geomanist', sans-serif;
            color: #000000;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background-color: #ffffff;
        }
        .contain {
            border-radius: 10px;
            background-color: #fcfcfc;
            padding: 20px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            border: 1px solid rgba(0, 0, 0, 0.1);            
        }
        #output {
            margin-top: 20px;
            padding: 10px;
            border-radius: 5px;
            background-color: #000000;
            color: #00e41e;
            font-family: monospace, monospace;
            width: 100%;
            max-width: 400px;
            text-align: center;
        }
    </style>
    <link rel="stylesheet" href="/sloginbtn.css">
</head>
<body>
    <div class="contain">
        <h1>StarLogin Test</h1>
        <span>This is a simple test page for the StarLogin API.</span>
        <span>Use this page to test out the StarLogin API's functionality.</span>
        <br>
        <button id="sl_login_button" class="sl_login_btn"><img src="/assets/skb.png" alt="StarKloud Logo" width="30" height="20"> Login with StarKloud</button>
        <a href="/dashboard">Visit the API Dashboard</a>
        <div class="output" id="output">Here is where the output will be displayed.</div>
    </div>
    <script>
    const loginButton = document.getElementById('sl_login_button');
    if (loginButton) {
        loginButton.addEventListener('click', function(){
            window.open('/login/hjCt6lbnL40Vdw5taFV8sPETfiAz5r', 'starlogin_auth_popup', 'width=500,height=700');
        });
    }
        window.addEventListener('message', function(event){
            if(event.origin !== window.location.origin) return; 
                 if(event.data.loginevent === 'login_success'){
                    console.log(event.data);
                    document.getElementById('output').textContent = JSON.stringify(event.data, null, 2);
                 }
        });

    </script>
</body>
</html>